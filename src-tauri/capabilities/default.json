{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "$HOME/**" }]
    },
    "dialog:default"
  ]
}
