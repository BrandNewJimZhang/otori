{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and the tray mini panel",
  "windows": ["main", "mini"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "$HOME/**" }]
    },
    "dialog:default"
  ]
}
